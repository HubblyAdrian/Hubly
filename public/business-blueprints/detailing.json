  "decisionRules": [
    {
      "id": "stale_portfolio",
      "if": {
        "portfolioAgeDays": {
          "gt": 14
        }
      },
      "then": {
        "recommend": "Upload 5 recent project photos"
      }
    },
    {
      "id": "ask_review",
      "if": {
        "daysSinceLastReviewAsk": {
          "gt": 7
        }
      },
      "then": {
        "recommend": "Ask yesterday’s customer for a review"
      }
    }
  ],
